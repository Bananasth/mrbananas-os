{
  "name": "mr-bananas-os",
  "version": "0.0.0",
  "private": true,
  "description": "Integrated operating system for a beverage & bakery business (Phase 0 foundation).",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "check:rls": "vitest run tests/rls-guard.test.ts",
    "coverage": "vitest run --coverage",
    "db:start": "npx --yes supabase start",
    "db:stop": "npx --yes supabase stop",
    "db:new": "npx --yes supabase migration new",
    "db:up": "npx --yes supabase migration up",
    "db:reset": "npx --yes supabase db reset",
    "db:diff": "npx --yes supabase db diff",
    "runtime:apply": "node tests/runtime/runtime.mjs apply",
    "runtime:seed": "node tests/runtime/runtime.mjs seed",
    "runtime:validate": "node tests/runtime/runtime.mjs validate",
    "runtime:phase2": "node tests/runtime/phase2-owner.mjs"
  },
  "dependencies": {
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.45.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.460.0",
    "next": "^15.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "server-only": "^0.0.1",
    "tailwind-merge": "^3.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^22.9.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitest/coverage-v8": "^4.0.0",
    "eslint": "^9.15.0",
    "pg": "^8.13.0",
    "prettier": "^3.3.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.13.0",
    "vitest": "^4.0.0"
  }
}
