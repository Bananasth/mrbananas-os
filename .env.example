# MR.BANANA'S OS — environment template
# Copy to `.env.local` and fill in. NEVER commit real values.
# Local Supabase values are printed by `supabase start` (wired in W4).
# Nothing in this repo is a real secret or connects to a hosted project.

NODE_ENV=development

# --- Supabase (local dev) ---
# Client-safe: RLS-gated. Default local API URL shown.
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
# Preferred: the new publishable key (sb_publishable_…). Falls back to the anon key.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=replace-with-publishable-key
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-local-anon-key

# Server-only: the service-role key BYPASSES Row Level Security.
# Never exposed to the browser, never committed. Used only in server/Edge contexts.
SUPABASE_SERVICE_ROLE_KEY=replace-with-local-service-role-key
