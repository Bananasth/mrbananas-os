# Copy to .env.local and fill in. NEVER commit real values (.env* is gitignored).
# Client-safe, RLS-gated public keys only — no service_role key, no DB password.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# Preferred: the new publishable key (sb_publishable_…). Falls back to the anon key.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=replace-with-publishable-key
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-anon-key
